# ─────────────────────────────────────────────────────────────────────────────
# Verifact environment configuration
# Copy this file to `.env` and fill in your keys.
#   cp .env.example .env      (macOS / Linux)
#   copy .env.example .env    (Windows)
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED. Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# OPTIONAL but recommended for reliable web search.
# Free tier: 1000 calls/month at https://tavily.com
# If left blank, Verifact falls back to the keyless DuckDuckGo wrapper.
TAVILY_API_KEY=

# OPTIONAL. If "1", prints a lot of detail while the graph runs. Default off.
VERIFACT_VERBOSE=0
